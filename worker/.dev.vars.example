# Replace this with documentation showing what secrets to push with wrangler.

# Copy this file to .dev.vars and fill in real values for local development.
# The .dev.vars file is gitignored. wrangler dev loads it automatically.

# Resend API key from https://resend.com/api-keys. Required.
RESEND_API_KEY=re_replace_me

# "From" address for outgoing mail. Until your Resend domain is verified,
# use the onboarding sender below. Once by-a-thread.de is verified in Resend,
# switch to something like "By a Thread <contact@by-a-thread.de>".
RESEND_FROM=By a Thread <onboarding@resend.dev>

# Where contact-form messages should land in your inbox.
CONTACT_TO=you@example.com

# Cloudflare Turnstile secret. The value below is the documented
# "always passes" test secret, suitable for local development. Replace with
# your real Turnstile secret before deploying.
# https://developers.cloudflare.com/turnstile/troubleshooting/testing/
TURNSTILE_SECRET=1x0000000000000000000000000000000AA
